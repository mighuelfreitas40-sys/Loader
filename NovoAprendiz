StatusLabel.Parent = Container

local Copied = false
local DiscordLink = "https://discord.gg/tKTwgd4xSb"

CopyBtn.MouseButton1Click:Connect(function()
    if Copied then return end

    local copySuccess = pcall(function()
        setclipboard(DiscordLink)
    end)

    if not copySuccess then
        StatusLabel.Text = "Erro ao copiar!"
        StatusLabel.TextColor3 = Color3.fromRGB(255, 80, 80)
        return
    end

    Copied = true
    CopyBtn.Text = "Link Copiado!"
    CopyBtn.BackgroundColor3 = Color3.fromRGB(50, 168, 82)
    StatusLabel.Text = "Carregando..."
    StatusLabel.TextColor3 = Color3.fromRGB(50, 200, 50)

    task.wait(1.5)

    local fadeInfo = TweenInfo.new(0.5, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)

    TweenService:Create(Frame, fadeInfo, { BackgroundTransparency = 1 }):Play()
    TweenService:Create(Container, fadeInfo, { BackgroundTransparency = 1 }):Play()
    TweenService:Create(ContainerStroke, fadeInfo, { Transparency = 1 }):Play()

    for _, v in pairs(Container:GetDescendants()) do
        if v:IsA("TextLabel") or v:IsA("TextButton") then
            TweenService:Create(v, fadeInfo, { TextTransparency = 1 }):Play()
        end
        if v:IsA("UIStroke") and v ~= ContainerStroke then
            TweenService:Create(v, fadeInfo, { Transparency = 1 }):Play()
        end
    end

    task.wait(0.6)
    ScreenGui:Destroy()

    local loadSuccess, loadResult = pcall(function()
        local src = game:HttpGet(U)
        if not src or type(src) ~= "string" or #src == 0 then
            error("HttpGet retornou vazio/nil")
        end
        local func, err = loadstring(src)
        if not func then
            error("loadstring falhou: " .. tostring(err))
        end
        return func()
    end)

    if not loadSuccess then
        warn("[NovoAprendiz] ERRO: " .. tostring(loadResult))
    end
end)
